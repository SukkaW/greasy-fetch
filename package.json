{
  "name": "greasy-fetch",
  "version": "1.0.0",
  "description": "You want to have modern `fetch` API in your userscript, but you also want to bypass the CORS restrictions via `GM.xmlHttpRequest`/`GM_xmlhttpRequest`. Now you can do both with `greasy-fetch`",
  "repository": {
    "url": "https://github.com/SukkaW/greasy-fetch.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "lint": "eslint --format=sukka .",
    "build": "bunchee --minify --no-sourcemap",
    "prerelease": "pnpm run lint && pnpm run build",
    "release": "bumpp --install -r --all --commit \"release: %s\" --tag \"%s\""
  },
  "keywords": [
    "XMLHttpRequest",
    "fetch",
    "Tampermonkey",
    "Violentmonkey",
    "Greasemonkey",
    "userscript",
    "greasyfork",
    "typescript"
  ],
  "author": "SukkaW <https://skk.moe>",
  "license": "MIT",
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/greasemonkey": "^4.0.7",
    "@types/greasemonkey3": "npm:@types/greasemonkey@^3.0.3",
    "bumpp": "^11.1.0",
    "bunchee": "^6.11.0",
    "earl": "^2.0.0",
    "eslint": "^10.6.0",
    "eslint-config-sukka": "^8.13.5",
    "eslint-formatter-sukka": "^8.13.5",
    "foxts": "^5.8.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0"
}
